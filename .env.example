# LndHub Configuration - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env FILE TO GIT - Add it to .gitignore

# Bitcoin RPC Configuration
BITCOIN_RPC_URL=http://user:password@localhost:8332/wallet/wallet.dat

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# LND Configuration
LND_HOST=localhost
LND_PORT=10009
LND_PASSWORD=your_lnd_password_here

# Server Configuration
NODE_ENV=production
PORT=3000

# Rate Limiting
RATE_LIMIT=200
POST_RATE_LIMIT=100

# Fees
FORWARD_RESERVE_FEE=0.01
INTRA_HUB_FEE=0.003

# Features
ENABLE_UPDATE_DESCRIBE_GRAPH=false
